# Example: Compare GC configs at different data scales
# This generates 3 x 2 = 6 combinations

docker_image=edge
test_package=io.deephaven.benchmark.tests.standard
test_class_list=Where,Avg*
test_iterations=1
distribution=random
config_options=-Xmx24g|-Xmx24g -XX:+UseZGC|-Xmx24g -XX:+UseShenandoahGC
scale_row_count=10|50
